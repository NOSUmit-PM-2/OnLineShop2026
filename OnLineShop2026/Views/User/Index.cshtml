@model User
@{
    ViewData["Title"] = "Профиль пользователя";
}

<div class="card" style="width: 18rem;">
    <img src="@Model.PhotoPath" class="card-img-top" alt="...">
    <div class="card-body">
        <h5 class="card-title">@Model.Name @Model.Sername</h5>
        <p class="card-text">@Model.Email</p>
        <a href="/Home/Catalog" class="btn btn-primary">В каталог</a>
    </div>
</div>

